<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Panel de Administración</title>
    <style>
        body { margin: 0; background: url('/fondo.png') no-repeat center center fixed; background-size: cover; font-family: sans-serif; }
        .container { background: rgba(255, 255, 255, 0.9); width: 80%; max-width: 600px; margin: 100px auto; padding: 30px; border-radius: 15px; text-align: center; }
        .btn { display: block; padding: 15px; margin: 10px; background: #004d99; color: white; text-decoration: none; border-radius: 8px; font-weight: bold; }
        .btn:hover { background: #003366; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Gestión de la Federación</h1>
        <p>Bienvenido al sistema genérico de fútbol</p>
        <a href="/nueva-federacion" class="btn">Registrar Nueva Federación</a>
        <a href="/nuevo-equipo" class="btn">Registrar Nuevo Equipo</a>
        <a href="/nuevo-jugador" class="btn">Registrar Nuevo Jugador</a>
        <br>
        <a href="/" style="color: red;">Cerrar Sesión</a>
    </div>
</body>
</html>