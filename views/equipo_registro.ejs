<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Registro de Equipo</title>
    <style>
        body { margin: 0; background: url('/fondo.png') no-repeat center center fixed; background-size: cover; font-family: sans-serif; }
        .form-card { background: rgba(255, 255, 255, 0.9); width: 400px; margin: 50px auto; padding: 30px; border-radius: 15px; }
    </style>
</head>
<body>
    <div class="form-card">
        <h2>Registrar Nuevo Equipo</h2>
        <form action="/guardar-equipo" method="POST">
            <input type="text" name="id" placeholder="ID Equipo" required style="width: 90%; margin-bottom: 10px;"><br>
            <input type="text" name="nombre" placeholder="Nombre del Equipo" required style="width: 90%; margin-bottom: 10px;"><br>
            
            <label>Seleccionar Federación:</label><br>
            <select name="id_federacion" required style="width: 95%; margin-bottom: 20px; padding: 5px;">
                <% federaciones.forEach(fed => { %>
                    <option value="<%= fed.id %>"><%= fed.nombre %></option>
                <% }) %>
            </select>

            <button type="submit" style="width: 100%; padding: 10px; background: #004d99; color: white; border: none; border-radius: 5px; cursor: pointer;">Guardar Equipo</button>
        </form>
        <br>
        <a href="/admin">Volver al Panel</a>
    </div>
</body>
</html>