<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Login - Federación de Fútbol</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-image: url('/fondo.png'); /* Aquí llamamos a tu imagen */
            background-size: cover;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: sans-serif;
        }
        .login-card {
            background: rgba(255, 255, 255, 0.9);
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <h1>Bienvenido</h1>
        <form action="/login" method="POST">
            <input type="email" placeholder="Usuario" required><br><br>
            <input type="password" placeholder="Contraseña" required><br><br>
            <button type="submit">Ingresar</button>
        </form>
    </div>
</body>
</html>